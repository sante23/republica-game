# Example environment file for production deployment
# Copy this file to .env.production and update the values

# Database
DB_PASSWORD=your_secure_database_password_here

# JWT Secret (minimum 32 characters)
JWT_SECRET=your_super_secure_jwt_secret_key_minimum_32_characters_here

# Redis Password
REDIS_PASSWORD=your_redis_password_here

# Application URL
CLIENT_URL=http://localhost

# Domain (for SSL certificates)
DOMAIN=localhost